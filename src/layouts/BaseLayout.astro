---
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogImage?: string;
  schema?: Record<string, unknown> | Record<string, unknown>[];
  noindex?: boolean;
}

const { title, description, canonicalUrl, ogImage, schema, noindex } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- Favicon -->
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <!-- Lexend: non-blocking font load (display=swap already in URL) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Lexend:wght@400;500;600;700&display=swap"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Lexend:wght@400;500;600;700&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Lexend:wght@400;500;600;700&display=swap"
        rel="stylesheet"
      />
    </noscript>

    <!-- Preload LCP hero candidate -->
    <link rel="preload" as="image" href="/images/hero-640.webp" type="image/webp" fetchpriority="high" />

    <!-- SEO Head (title, meta, OG, Twitter, schema) -->
    <SEO
      title={title}
      description={description}
      canonicalUrl={canonicalUrl}
      ogImage={ogImage}
      schema={schema}
      noindex={noindex}
    />

    <!-- GA4 -->
    {import.meta.env.PROD && (
      <script async src="https://www.googletagmanager.com/gtag/js?id=G-FNX2VQ6P5M" />
      <script is:inline>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', 'G-FNX2VQ6P5M');
      </script>
    )}
  </head>

  <body class="flex min-h-screen flex-col bg-[#FAF9F6] text-stone-900 antialiased font-body">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-[100] focus:bg-black focus:px-3 focus:py-2 focus:text-white">Skip to main content</a>
    <Header />
    <main id="main-content" class="flex-1">
      <slot />
    </main>
    <Footer />
    <!-- GoHighLevel chat widget (deferred so it does not compete with LCP) -->
    <script is:inline>
      window.addEventListener('load', function () {
        var s = document.createElement('script');
        s.src = 'https://widgets.leadconnectorhq.com/loader.js';
        s.setAttribute('data-resources-url', 'https://widgets.leadconnectorhq.com/chat-widget/loader.js');
        s.setAttribute('data-widget-id', '6a5bffc2c02522215a5615c0');
        s.async = true;
        document.body.appendChild(s);
      });
    </script>
  </body>
</html>
