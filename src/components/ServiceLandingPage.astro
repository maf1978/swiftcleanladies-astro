---
import { Icon } from 'astro-icon/components';
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from './Breadcrumbs.astro';
import LandingFaq from './LandingFaq.astro';
import SeoTestimonials from './SeoTestimonials.astro';
import { business } from '../data/business';
import { getAreaBySlug } from '../data/serviceAreas';
import { getServiceBySlug } from '../data/serviceTypes';
import type { ServiceLanding } from '../data/serviceLandings';
import { contactUrl } from '../lib/urls';

interface Props {
  landing: ServiceLanding;
}

const { landing } = Astro.props;
const area = getAreaBySlug(landing.reviewAreaSlug || 'crawfordville')!;
const service = landing.reviewServiceSlug
  ? getServiceBySlug(landing.reviewServiceSlug)
  : undefined;

const canonicalUrl = `${business.website}/${landing.slug}/`;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: landing.h1,
  description: landing.explanation,
  provider: {
    '@type': 'CleaningService',
    name: business.name,
    telephone: business.phone,
    url: business.website,
    address: {
      '@type': 'PostalAddress',
      streetAddress: business.address.street,
      addressLocality: business.address.city,
      addressRegion: business.address.state,
      postalCode: business.address.zip,
      addressCountry: 'US',
    },
    areaServed: business.serviceRadius,
  },
  areaServed: landing.areas.map((a) => a.name),
  url: canonicalUrl,
};
---

<BaseLayout
  title={landing.title}
  description={landing.metaDescription}
  canonicalUrl={canonicalUrl}
  schema={schema}
>
  <Breadcrumbs crumbs={[{ label: landing.h1 }]} />

  <!-- Hero -->
  <section class="border-b border-stone-200 bg-gradient-to-br from-stone-50 to-brand-50/40">
    <div class="mx-auto max-w-7xl px-5 py-12 lg:px-8 lg:py-16">
      <div class="lg:flex lg:items-start lg:gap-12">
        <div class="lg:flex-1">
          <div class="flex items-center gap-3 text-brand-700">
            <Icon name={landing.icon} class="size-8" />
            <span class="text-sm font-semibold uppercase tracking-wide">{business.name}</span>
          </div>
          <h1 class="mt-4 font-display text-3xl text-brand-900 sm:text-4xl lg:text-5xl">
            {landing.h1}
          </h1>
          <p class="mt-5 max-w-2xl text-lg leading-relaxed text-stone-600">
            {landing.explanation}
          </p>
          <div class="mt-8 flex flex-wrap gap-4">
            <a
              href={contactUrl()}
              class="inline-flex items-center gap-2 rounded-lg bg-brand-700 px-6 py-3 text-sm font-semibold text-white shadow transition-colors hover:bg-brand-800"
            >
              <Icon name="lucide:message-square" class="size-4" />
              Request a Free Quote
            </a>
            <a
              href={business.phoneHref}
              class="inline-flex items-center gap-2 rounded-lg border border-brand-300 bg-white px-6 py-3 text-sm font-semibold text-brand-800 transition-colors hover:bg-brand-50"
            >
              <Icon name="lucide:phone" class="size-4" />
              Call {business.phone}
            </a>
          </div>
          <p class="mt-4 text-sm text-stone-500">
            {business.name} · {business.license} · Serving {business.serviceRadius}
          </p>
        </div>
        <div class="mt-8 lg:mt-0 lg:w-[28rem] lg:shrink-0">
          <img
            src={landing.heroImage}
            alt={landing.heroImageAlt}
            class="w-full rounded-xl shadow-lg"
            width="1024"
            height="1024"
            loading="eager"
            fetchpriority="high"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- What's included -->
  <section class="py-16">
    <div class="mx-auto max-w-7xl px-5 lg:px-8">
      <h2 class="font-display text-2xl text-brand-900 sm:text-3xl">What Is Included</h2>
      <p class="mt-3 max-w-2xl text-stone-600">
        Scope is confirmed during your free quote. Typical inclusions for this service:
      </p>
      <ul class="mt-8 grid gap-3 sm:grid-cols-2">
        {
          landing.included.map((item) => (
            <li class="flex gap-3 text-stone-700">
              <Icon name="lucide:check-circle-2" class="mt-0.5 size-5 shrink-0 text-brand-600" />
              <span>{item}</span>
            </li>
          ))
        }
      </ul>
      {
        landing.relatedServiceHref && (
          <p class="mt-6 text-sm">
            <a href={landing.relatedServiceHref} class="font-semibold text-brand-700 underline-offset-2 hover:underline">
              {landing.relatedServiceLabel || 'See full service details'}
            </a>
          </p>
        )
      }
    </div>
  </section>

  <!-- Who it's for -->
  <section class="border-y border-stone-200 bg-stone-50 py-16">
    <div class="mx-auto max-w-7xl px-5 lg:px-8">
      <h2 class="font-display text-2xl text-brand-900 sm:text-3xl">Who This Service Is For</h2>
      <ul class="mt-8 grid gap-4 sm:grid-cols-2">
        {
          landing.whoFor.map((item) => (
            <li class="flex gap-3 rounded-lg border border-stone-200 bg-white p-5 text-stone-700">
              <Icon name="lucide:user-check" class="mt-0.5 size-5 shrink-0 text-brand-600" />
              <span>{item}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- Areas served -->
  <section class="py-16">
    <div class="mx-auto max-w-7xl px-5 lg:px-8">
      <h2 class="font-display text-2xl text-brand-900 sm:text-3xl">Areas Served</h2>
      <p class="mt-3 max-w-2xl text-stone-600">
        {business.name} serves {business.serviceRadius}. Phone {business.phone}. Address:{' '}
        {business.address.street}, {business.address.city}, {business.address.state}{' '}
        {business.address.zip}.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        {
          landing.areas.map((a) => (
            <a
              href={a.href}
              class="rounded-lg border border-brand-200 bg-brand-50 px-4 py-2 text-sm font-semibold text-brand-800 transition-colors hover:bg-brand-100"
            >
              {a.name}
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Photos (real site service imagery — not invented project captions) -->
  <section class="border-y border-stone-200 bg-stone-50 py-16">
    <div class="mx-auto max-w-7xl px-5 lg:px-8">
      <h2 class="font-display text-2xl text-brand-900 sm:text-3xl">Service Photos</h2>
      <p class="mt-3 max-w-2xl text-sm text-stone-600">
        Photos from SwiftClean Ladies service imagery used across our site. Ask during your quote if you want to discuss your property type in more detail.
      </p>
      <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {
          landing.photos.map((photo) => (
            <figure>
              <img
                src={photo.src}
                alt={photo.alt}
                class="aspect-square w-full rounded-xl object-cover shadow"
                width="640"
                height="640"
                loading="lazy"
              />
              <figcaption class="mt-2 text-xs leading-snug text-stone-500">{photo.caption}</figcaption>
            </figure>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Testimonials (real reviews only) -->
  <div class="mx-auto max-w-7xl px-5 lg:px-8">
    <SeoTestimonials area={area} service={service} />
  </div>

  <!-- FAQ -->
  <LandingFaq heading={`Frequently Asked Questions — ${landing.h1}`} faqs={landing.faqs} />

  <!-- Related links -->
  {
    landing.relatedLinks && landing.relatedLinks.length > 0 && (
      <section class="pb-8">
        <div class="mx-auto max-w-7xl px-5 lg:px-8">
          <h2 class="font-display text-xl text-brand-900">Related Guides</h2>
          <ul class="mt-4 flex flex-wrap gap-x-6 gap-y-2 text-sm">
            {landing.relatedLinks.map((link) => (
              <li>
                <a href={link.href} class="font-medium text-brand-700 underline-offset-2 hover:underline">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </section>
    )
  }

  <!-- Bottom CTA + NAP -->
  <section class="bg-brand-900 py-14 text-white">
    <div class="mx-auto max-w-7xl px-5 lg:px-8">
      <h2 class="font-display text-2xl sm:text-3xl">Request a Free Quote</h2>
      <p class="mt-3 max-w-2xl text-brand-100">
        {business.name} is {business.license.toLowerCase()}. Serving {business.serviceRadius}. Tell us
        your address and priorities — we confirm scope before any visit.
      </p>
      <div class="mt-8 flex flex-wrap gap-4">
        <a
          href={contactUrl()}
          class="inline-flex items-center gap-2 rounded-lg bg-amber-400 px-6 py-3 text-sm font-semibold text-brand-950 transition-colors hover:bg-amber-300"
        >
          <Icon name="lucide:message-square" class="size-4" />
          Request a Free Quote
        </a>
        <a
          href={business.phoneHref}
          class="inline-flex items-center gap-2 rounded-lg border border-white/30 px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-white/10"
        >
          <Icon name="lucide:phone" class="size-4" />
          {business.phone}
        </a>
      </div>
      <p class="mt-6 text-sm text-brand-200">
        {business.name} · {business.address.street}, {business.address.city}, {business.address.state}{' '}
        {business.address.zip} · {business.email}
      </p>
    </div>
  </section>
</BaseLayout>
