---
import { Icon } from 'astro-icon/components';
import type { FaqItem } from '../data/seoContent';

interface Props {
  heading: string;
  faqs: FaqItem[];
}

const { heading, faqs } = Astro.props;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
};
---

<section class="py-16">
  <div class="mx-auto max-w-3xl px-5 lg:px-8">
    <h2 class="font-display text-2xl text-brand-900 sm:text-3xl">{heading}</h2>
    <div class="mt-8 space-y-3">
      {
        faqs.map((faq) => (
          <details class="group rounded-lg border border-stone-200 bg-white transition-colors hover:border-stone-300">
            <summary class="flex cursor-pointer items-center justify-between gap-4 px-5 py-4 text-sm font-medium text-stone-800 [&::-webkit-details-marker]:hidden [&::marker]:hidden">
              <span>{faq.question}</span>
              <Icon
                name="lucide:chevron-down"
                class="size-5 shrink-0 text-stone-400 transition-transform duration-200 group-open:rotate-180"
              />
            </summary>
            <div class="border-t border-stone-100 px-5 py-4 text-sm leading-relaxed text-stone-600">
              {faq.answer}
            </div>
          </details>
        ))
      }
    </div>
  </div>
</section>

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
