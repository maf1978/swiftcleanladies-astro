---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { Icon } from 'astro-icon/components';
import { business } from '../data/business';
import { serviceAreas } from '../data/serviceAreas';
import { areaUrl, contactUrl } from '../lib/urls';
---

<BaseLayout
  title={`About ${business.name} | Professional Cleaning in Crawfordville, FL`}
  description={`Learn about ${business.name}, a locally owned cleaning team serving ${business.serviceRadius}. ${business.license}.`}
>
  <Breadcrumbs crumbs={[{ label: 'About' }]} />

  <!-- ============ HEADER ============ -->
  <section class="py-12 lg:py-16">
    <div class="mx-auto max-w-7xl px-5 lg:px-8">
      <div class="max-w-3xl animate-fade-up">
        <h1 class="font-display text-4xl text-brand-900 sm:text-5xl">
          About {business.name}
        </h1>
        <p class="mt-4 text-lg leading-relaxed text-stone-600">
          Locally owned, licensed, and insured. Our team delivers dependable cleaning for homes,
          offices, and new developments across the Florida Big Bend.
        </p>
      </div>
    </div>
  </section>

  <!-- ============ OUR STORY ============ -->
  <section class="pb-16 lg:pb-24">
    <div class="mx-auto max-w-7xl px-5 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-2 lg:gap-16">
        <!-- Story content -->
        <div class="prose-editorial">
          <h2>Our Story</h2>
          <p>
            {business.name} was built around a simple goal: give Crawfordville and nearby communities
            cleaning that is reliable, respectful, and easy to schedule. We focus on the rooms and
            routines that matter most to you, not one-size-fits-all packages.
          </p>
          <p>
            What started as a small local crew has grown into a trusted team serving
            {business.serviceRadius}. Every visit is handled by people who know the area, from
            coastal humidity in Saint Marks and Panacea to busy offices in Tallahassee.
          </p>
          <p>
            We believe in clear communication, fair quotes, and treating every home and workspace
            with care. That approach shows up in the reviews our clients leave and in the repeat
            schedules we maintain week after week.
          </p>
          <p>
            Whether you need a one-time deep clean before guests arrive or recurring residential
            care, we show up on time, follow your checklist, and leave spaces ready to use.
          </p>
        </div>

        <!-- Team spotlight -->
        <div>
          <div class="rounded-xl border border-stone-200 bg-white p-8">
            <div class="flex items-center gap-4">
              <div class="flex size-16 items-center justify-center rounded-full bg-brand-100">
                <Icon name="lucide:users" class="size-8 text-brand-700" />
              </div>
              <div>
                <h3 class="font-display text-xl text-brand-900">{business.owner}</h3>
                <p class="text-sm text-stone-500">Professional Cleaning Team</p>
              </div>
            </div>
            <div class="mt-6 space-y-3 text-sm leading-relaxed text-stone-600">
              <p>
                The {business.name} crew handles residential, commercial, and new-construction
                cleaning across Wakulla and Leon Counties. We work in pairs or small teams so
                visits stay efficient without cutting corners on detail.
              </p>
              <p>
                When you call or request a quote, you talk with people who know the schedule,
                the service area, and what each type of clean includes. That keeps expectations
                clear from the first message to the final walkthrough.
              </p>
            </div>
            <div class="mt-6 border-t border-stone-100 pt-6">
              <p class="text-xs font-medium uppercase tracking-wider text-stone-400">Credentials</p>
              <div class="mt-2 flex flex-wrap gap-2">
                <span class="inline-flex items-center gap-1.5 rounded-full bg-brand-50 px-3 py-1 text-xs font-medium text-brand-700">
                  <Icon name="lucide:badge-check" class="size-3.5" />
                  {business.license}
                </span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ TRUST SIGNALS ============ -->
  <section class="bg-stone-100 py-16 lg:py-24">
    <div class="mx-auto max-w-7xl px-5 lg:px-8">
      <h2 class="text-center font-display text-3xl text-brand-900">
        Why Customers Trust Us
      </h2>

      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {[
          {
            icon: 'lucide:badge-check',
            title: 'Licensed',
            detail: business.license,
          },
          {
            icon: 'lucide:shield',
            title: 'Fully Insured',
            detail: 'Coverage on every visit for your peace of mind.',
          },
          {
            icon: 'lucide:heart-handshake',
            title: 'Locally Owned',
            detail: `Based in Crawfordville and serving ${business.serviceRadius}.`,
          },
          {
            icon: 'lucide:sparkles',
            title: 'Detail-Focused',
            detail: 'Kitchens, baths, floors, and add-ons scoped to your priorities.',
          },
        ].map((item, i) => (
          <div class={`rounded-xl border border-stone-200 bg-white p-6 animate-fade-up stagger-${i + 1}`}>
            <div class="flex size-12 items-center justify-center rounded-lg bg-brand-50 text-brand-700">
              <Icon name={item.icon} class="size-6" />
            </div>
            <h3 class="mt-4 font-display text-lg text-brand-900">{item.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-stone-600">{item.detail}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ AREAS WE COVER ============ -->
  <section class="py-16 lg:py-24">
    <div class="mx-auto max-w-7xl px-5 lg:px-8">
      <h2 class="text-center font-display text-3xl text-brand-900">
        Communities We Serve
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-center text-stone-600">
        We provide cleaning services throughout {business.serviceRadius}.
        Here are the communities where we are most active.
      </p>

      <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {serviceAreas.map((area) => (
          <a
            href={areaUrl(area.slug)}
            class="card-hover flex items-center gap-3 rounded-xl border border-stone-200 bg-white px-5 py-4 transition-colors"
          >
            <Icon name="lucide:map-pin" class="size-5 shrink-0 text-brand-600" />
            <div>
              <span class="font-medium text-brand-900">{area.name}</span>
              <span class="block text-xs text-stone-500">{area.county}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ CTA ============ -->
  <section class="bg-brand-900">
    <div class="mx-auto max-w-7xl px-5 py-12 lg:px-8 lg:py-16">
      <div class="flex flex-col items-center gap-6 text-center sm:flex-row sm:justify-between sm:text-left">
        <div>
          <h2 class="font-display text-3xl text-white">Ready to Work With Us?</h2>
          <p class="mt-2 text-brand-200">
            Call today for a free quote or send us a message online. We look forward to earning your trust.
          </p>
        </div>
        <div class="flex shrink-0 flex-wrap gap-4">
          <a
            href={business.phoneHref}
            class="inline-flex items-center gap-2 rounded-lg bg-amber-500 px-6 py-3 text-sm font-semibold text-brand-950 shadow-lg transition-all hover:bg-amber-400"
          >
            <Icon name="lucide:phone" class="size-5" />
            {business.phone}
          </a>
          <a
            href={contactUrl()}
            class="inline-flex items-center gap-2 rounded-lg border border-white/20 bg-white/10 px-6 py-3 text-sm font-semibold text-white transition-all hover:bg-white/20"
          >
            Contact Us
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
